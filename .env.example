# ==========================================
# 🚀 AutoDocGen 通用大模型配置文件
# ==========================================

# 你的 API Key
API_KEY=your_api_key_here

# API 接口地址 (Base URL)
# ------------------------------------------
# 默认 (OpenAI): https://api.openai.com/v1
# Gemini 兼容: https://generativelanguage.googleapis.com/v1beta/openai/
# DeepSeek: https://api.deepseek.com
BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 指定的大模型名称
# ------------------------------------------
# 默认: gpt-3.5-turbo
# Gemini 示例: gemini-1.5-flash 或 gemini-1.5-pro
MODEL_NAME=gemini-1.5-flash
